# --- Database (Neon) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# 32+ chars random. Generate with: openssl rand -base64 48
SESSION_PASSWORD=replace-with-32+char-random-string-replace-with-32+char-random

# --- Admin (login with email + password) ---
[email protected]
# Generate with: npx tsx scripts/admin-password.ts <password>
ADMIN_PASSWORD_HASH=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
CURRENCY=aud

# --- Printify (https://printify.com/app/account/api) ---
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=
# Webhook secret from Printify dashboard → Webhooks. Endpoint: /api/webhooks/printify
PRINTIFY_WEBHOOK_SECRET=

# --- Australia Post PAC API (https://developers.auspost.com.au) ---
AUSPOST_API_KEY=
AUSPOST_FROM_POSTCODE=2000
# Default parcel dimensions (folded apparel). Override per your packaging.
AUSPOST_PARCEL_LENGTH_CM=22
AUSPOST_PARCEL_WIDTH_CM=16
AUSPOST_PARCEL_HEIGHT_CM=4
AUSPOST_WEIGHT_PER_ITEM_KG=0.25
AUSPOST_MIN_WEIGHT_KG=0.5

# --- Email (Resend.com) for passwordless OTP. Optional in dev — code logs to server console. ---
RESEND_API_KEY=
MAIL_FROM="Koalafied <noreply@koalafied.store>"

# --- Free image hosting for admin product uploads (https://api.imgbb.com/) ---
# Sign up free at imgbb.com → Get API key. Without it, uploads fall back to /public/uploads (dev only).
IMGBB_API_KEY=
